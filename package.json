{
  "name": "hqbase",
  "version": "0.1.17",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "hqbaseRelease": {
    "minimumVersion": "0.1.3"
  },
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "dev:vite": "vite --host 127.0.0.1 --port 5173",
    "build": "vite build",
    "deploy": "node scripts/release/deploy.mjs",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "code:check": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.worker.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:architecture": "node scripts/check-architecture.mjs",
    "test:e2e:staging": "playwright test --config playwright.config.ts",
    "check": "pnpm code:check && pnpm typecheck && pnpm test && pnpm test:coverage && pnpm test:architecture && pnpm build",
    "deploy:dry-run": "pnpm build && wrangler deploy --dry-run",
    "hqbase": "node scripts/hqbase/cli.mjs",
    "hqbase:button": "node scripts/hqbase/cli.mjs button",
    "hqbase:install": "node scripts/hqbase/cli.mjs install",
    "hqbase:doctor": "node scripts/hqbase/cli.mjs doctor",
    "hqbase:reset": "node scripts/hqbase/cli.mjs reset",
    "hqbase:destroy": "node scripts/hqbase/cli.mjs destroy",
    "cf:typegen": "wrangler types",
    "release:package": "node scripts/release/package.mjs"
  },
  "cloudflare": {
    "bindings": {
      "DB": {
        "description": "Cloudflare D1 database used for Better Auth, setup state, mailboxes, threads, and message metadata."
      },
      "MAIL_OBJECTS": {
        "description": "Cloudflare R2 bucket used for raw emails, HTML bodies, and attachments."
      },
      "MAIL_SENDER": {
        "description": "Cloudflare Email Sending binding. The sending domain must be onboarded in Cloudflare Email Service."
      },
      "ASSETS": {
        "description": "Worker Static Assets binding serving the Vite build output from `dist`."
      }
    }
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "better-auth": "^1.3.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.8.5",
    "lucide-react": "^0.525.0",
    "postal-mime": "^2.5.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sanitize-html": "^2.17.6",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@playwright/test": "1.61.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "4.1.10",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^7.0.5",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
